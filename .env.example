# =============================================================================
# EMPATHY FOR THE DEVIL - Variabili d'ambiente (TEMPLATE)
# -----------------------------------------------------------------------------
# Copia questo file in ".env" e inserisci le tue chiavi.
#   cp .env.example .env
# Il file .env e' ignorato da git (vedi .gitignore): NON pubblicarlo mai.
# =============================================================================

# ===== Musixmatch API (core dell'hackathon) =====
# Ottieni la chiave su https://developer.musixmatch.com/
MUSIXMATCH_API_KEY=
# Sorgenti di ricerca Musixmatch (attivabili in modo indipendente).
# - MUSIXMATCH_USE_LYRICS: query basate sui TESTI (q/q_track/q_artist/q_lyrics) — default: true
# - MUSIXMATCH_USE_MEANING: ricerca per SIGNIFICATO (track.lyrics.analysis.search) — default: false
#   (disattivata di default: da sola tende a restituire sempre gli stessi brani popolari).
# Possono stare insieme o da sole. Non influenzano il piano dell'LLM ne' il check.
# - MUSIXMATCH_USE_FINGERPRINT: stabilizza l'identita' del brano (Spotify ID/ISRC/
#   genere/cover) dal TESTO via track.lyrics.fingerprint.post — default: true
#   (endpoint Enterprise "Sentinel": su piani inferiori risponde 403 e degrada in
#   silenzio, quindi e' sicuro lasciarlo attivo).
MUSIXMATCH_USE_LYRICS=true
MUSIXMATCH_USE_MEANING=false
MUSIXMATCH_USE_FINGERPRINT=true

# ===== TheAudioDB (biografie multilingua + immagini artisti) =====
# "123" e' la chiave di test pubblica gratuita. Per produzione usa la tua.
AUDIODB_API_KEY=123

# ===== Motore LLM "Thinking" (OpenRouter / OpenAI-compatible) =====
# Modelli selezionabili anche dalla sidebar:
#   google/gemma-4-31b-it:free
#   nvidia/nemotron-3-ultra-550b-a55b:free
#   nvidia/nemotron-3-super-120b-a12b:free
#   openrouter/owl-alpha
#   nex-agi/nex-n2-pro:free
#   openai/gpt-oss-120b:free
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free
LLM_TIMEOUT_SECONDS=20

# ===== ElevenLabs TTS (narrazione con voce AI) =====
# Ottieni la chiave su https://elevenlabs.io/
# Se resta vuoto, la narrazione vocale viene disabilitata: non viene usato alcun fallback browser.
ELEVENLABS_API_KEY=
# Voice ID del personaggio (default: George - caldo, narrativo).
# Trova i tuoi voice ID su https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# In locale puoi lasciare "auto": usa un endpoint su 127.0.0.1 per generare audio on-demand.
# Su Streamlit Cloud imposta "embedded" nei Secrets, altrimenti il browser non puo' raggiungere 127.0.0.1 del container.
SONDER_TTS_MODE=auto

# ===== Spotify (login per-utente con PKCE) =====
# Ogni visitatore accede col PROPRIO account: serve SOLO il Client ID (pubblico).
#   1. Crea un'app su https://developer.spotify.com/dashboard
#   2. In "Redirect URIs" aggiungi ESATTAMENTE l'URL dell'app (qui sotto).
#      ATTENZIONE: Spotify NON accetta "localhost": usa http://127.0.0.1:8501
#      e apri l'app dallo stesso indirizzo (non da localhost).
#   3. Copia solo il Client ID (il SECRET NON serve con PKCE).
# La riproduzione integrale richiede un account Spotify Premium.
SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET non e' piu' necessario (flusso PKCE per-utente).
SPOTIFY_CLIENT_SECRET=
# Deve combaciare con la URL su cui apri l'app e con la Redirect URI registrata.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8501

# ===== Songstats (statistiche di streaming/popolarita' reali) =====
# Ottieni la chiave su https://songstats.com/api (usata nell'header "apikey").
# Alimenta i grafici/statistiche a fondo pagina e la soglia di notorieta'
# (esclude i brani con meno di ~10.000 stream). Se vuota: modalita' demo.
SONGSTATS_API_KEY=
