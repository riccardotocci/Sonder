# =============================================================================
# EMPATHY FOR THE DEVIL - Variabili d'ambiente (TEMPLATE)
# -----------------------------------------------------------------------------
# Copia questo file in ".env" e inserisci le tue chiavi.
#   cp .env.example .env
# Il file .env e' ignorato da git (vedi .gitignore): NON pubblicarlo mai.
# =============================================================================

# ===== Musixmatch API (core dell'hackathon) =====
# Ottieni la chiave su https://developer.musixmatch.com/
MUSIXMATCH_API_KEY=

# ===== TheAudioDB (biografie multilingua + immagini artisti) =====
# "123" e' la chiave di test pubblica gratuita. Per produzione usa la tua.
AUDIODB_API_KEY=123

# ===== Last.fm API (biografie + statistiche ascolto) =====
# Ottieni la chiave su https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ===== Motore LLM "Thinking" (OpenRouter / OpenAI / DeepSeek) =====
# Esempi di base URL:
#   OpenRouter -> https://openrouter.ai/api/v1   (model: deepseek/deepseek-r1)
#   OpenAI     -> https://api.openai.com/v1       (model: o3-mini / o1-mini)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-r1

# ===== ElevenLabs TTS (narrazione con voce AI) =====
# Ottieni la chiave su https://elevenlabs.io/
# Se resta vuoto, la narrazione vocale viene disabilitata: non viene usato alcun fallback browser.
ELEVENLABS_API_KEY=
# Voice ID del personaggio (default: George - caldo, narrativo).
# Trova i tuoi voice ID su https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ===== Spotify (login per-utente con PKCE) =====
# Ogni visitatore accede col PROPRIO account: serve SOLO il Client ID (pubblico).
#   1. Crea un'app su https://developer.spotify.com/dashboard
#   2. In "Redirect URIs" aggiungi ESATTAMENTE l'URL dell'app (qui sotto).
#      ATTENZIONE: Spotify NON accetta "localhost": usa http://127.0.0.1:8501
#      e apri l'app dallo stesso indirizzo (non da localhost).
#   3. Copia solo il Client ID (il SECRET NON serve con PKCE).
# La riproduzione integrale richiede un account Spotify Premium.
SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET non e' piu' necessario (flusso PKCE per-utente).
SPOTIFY_CLIENT_SECRET=
# Deve combaciare con la URL su cui apri l'app e con la Redirect URI registrata.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8501
